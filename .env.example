# Chave da API Anthropic (obrigatório)
ANTHROPIC_API_KEY=sua-chave-aqui

# Databricks (preencher para usar fonte de dados via Datalake)
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<personal-access-token>
DATABRICKS_CLUSTER_ID=<cluster-id>
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=default

# Caminhos padrão para os PDFs (opcional — fallback quando Databricks não configurado)
DEFAULT_BALANCETE=/caminho/para/balancete.pdf
DEFAULT_CONTA_CORRENTE=/caminho/para/conta_corrente.pdf
